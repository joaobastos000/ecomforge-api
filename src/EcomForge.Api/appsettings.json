{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=ecomforge;Username=ecomforge;Password=ecomforge",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "EcomForge",
    "Audience": "EcomForge.Client",
    "Secret": "change-this-development-secret-with-at-least-32-characters",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "AI": {
    "Provider": "OpenAI",
    "Model": "gpt-4.1-mini",
    "ApiKey": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
